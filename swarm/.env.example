# ═══════════════════════════════════════════════════════════════════
# KRATOS v2 — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ── LLM (Required) ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...   # Optional Claude fallback

# ── Broker: OANDA (Primary Execution) ────────────────────────────────
# Practice: https://api-fxpractice.oanda.com
# Live:     https://api-fxtrade.oanda.com
OANDA_API_KEY=your-oanda-api-key
OANDA_ACCOUNT_ID=your-account-id
OANDA_BASE_URL=https://api-fxpractice.oanda.com

# ── Broker: Deriv (Alternative WebSocket) ────────────────────────────
DERIV_API_KEY=your-deriv-api-key
DERIV_APP_ID=your-deriv-app-id
DERIV_ENDPOINT=wss://ws.binaryws.com/websockets/v3

# ── Kronos Foundation Model (HuggingFace) ────────────────────────────
# Models: NeoQuasar/Kronos-mini | Kronos-small | Kronos-base
KRONOS_MODEL_ID=NeoQuasar/Kronos-small
KRONOS_TOKENIZER_ID=NeoQuasar/Kronos-Tokenizer-base
KRONOS_CONTEXT=400
KRONOS_PRED_LEN=10
HUGGINGFACE_TOKEN=hf_...         # Only needed for private models

# ── Crucix Intelligence (FRED + BLS + News) ───────────────────────────
FRED_API_KEY=your-fred-api-key   # https://fred.stlouisfed.org/docs/api/api_key.html
BLS_API_KEY=your-bls-key         # Optional: https://data.bls.gov/registrationEngine/
NEWS_API_KEY=your-newsapi-org-key  # https://newsapi.org

# ── Gmail Signal Monitoring ───────────────────────────────────────────
REPORT_EMAIL=mcbrian@youremail.com

# ── Account / Risk ────────────────────────────────────────────────────
ACCOUNT_EQUITY=10000
MAX_DAILY_DRAWDOWN_PCT=5         # 5% daily drawdown limit
MAX_OPEN_TRADES=3
CONSENSUS_THRESHOLD=0.70

# ── Trading Pairs ─────────────────────────────────────────────────────
WATCH_PAIRS=EURUSD,GBPUSD,USDJPY,XAUUSD,USDCHF,AUDUSD

# ── Run Mode ──────────────────────────────────────────────────────────
# sim   = simulate trades (no real orders)
# live  = real execution via broker
RUN_MODE=sim
LOG_LEVEL=INFO

# ── OpenBB (Optional SDK) ─────────────────────────────────────────────
# OPENBB_PAT=your-openbb-personal-access-token
